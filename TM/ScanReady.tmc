/* ScanReady.tmc */
TM typedef uint8_t ScanReady_t { text "%1d"; }

/* ScanReady is a boolean that is true when the IFS125 is in either
   IFS_SCAN_WAIT (after the end of a scan) or IFS_SCAN_IDLE (after
   the end of an idle scan). In any other situation, it is considered
   to be 'busy' doing something else, possibly scanning.
 */

ScanReady_t ScanReady; Invalidate ScanReady;
{ ScanReady = IFSCStat == IFS_SCAN_IDLE || IFSCStat == IFS_SCAN_WAIT;
  Validate ScanReady;
}
